::Const.GetFactionArchetypesList <- function () {
	local result = [];
	for (local i = 0; i < this.Const.FactionArchetypes.len(); i = ++i) {
		for (local j = 0; j < this.Const.FactionArchetypes[i].len(); j = ++j) {
			result.push([i, j]);
		}
	}
	return result;
};

::Const.GetFactionNobleFlavorText <- function (_faction) {
	if (_faction == null || _faction.getType() != this.Const.FactionType.NobleHouse) {
		return "";
	}

	local text = "";

	local motto = _faction.getMotto();
	if (motto != null && motto != "") {
		text += "\n[i]" + motto + "[/i]";
	}

	local formattedTraits = [];

	foreach (key, val in this.Const.FactionTrait) {
		if (val == this.Const.FactionTrait.NobleHouse) {
			continue;
		}

		if (_faction.hasTrait(val)) {
			local displayName = key; // for debugging
			local displayColor = "";

			if (val in ::Const.FactionNobleTraitConfig) {
				displayName = ::Const.FactionNobleTraitConfig[val].Name;
				displayColor = ::Const.FactionNobleTraitConfig[val].Color;
			}

			formattedTraits.push(displayColor != ""	? ::Const.UI.getColorized(displayName, displayColor) : displayName);
		}
	}

	if (formattedTraits.len() > 0) {
		local traitsLine = "";
		for (local i = 0; i < formattedTraits.len(); i = ++i) {
			traitsLine = traitsLine + formattedTraits[i];
			if (i < formattedTraits.len() - 1) {
				traitsLine = traitsLine + ", ";
			}
		}
		text += "\n" + traitsLine;
	}

	return text;
};

::Const.GetFactionNobleTraitsForRelationsScreen <- function (_faction) {
	if (_faction == null || _faction.getType() != this.Const.FactionType.NobleHouse) {
		return "";
	}

	local result = [];

	foreach (key, val in this.Const.FactionTrait) {
		if (val == this.Const.FactionTrait.NobleHouse) {
			continue;
		}

		if (_faction.hasTrait(val)) {
			result.push({
				ID = val,
				Name = ::Const.FactionNobleTraitConfig[val].Name,
				Color = ::Const.FactionNobleTraitConfig[val].Color,
			});
		}
	}

	return result;
};
